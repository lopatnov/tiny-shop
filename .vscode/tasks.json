{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cargo build",
      "type": "cargo",
      "command": "build",
      "args": ["--workspace"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo test",
      "type": "cargo",
      "command": "test",
      "args": ["--workspace"],
      "group": "test",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo clippy",
      "type": "cargo",
      "command": "clippy",
      "args": ["--workspace", "--all-targets", "--", "-D", "warnings"],
      "problemMatcher": ["$rustc"]
    }
  ]
}
